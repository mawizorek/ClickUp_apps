{
  "schemaVersion": 1,
  "contract": "global",
  "note": "GLOBAL theme contract. Shared by ClickUp HTML apps (Pages-hosted, resolve live) AND FileMaker layout renders (local design mockups, tokens inlined at render time). One vocabulary, one source of truth. Change a theme file once and every consumer that references its slug reskins.",
  "ultimateFallback": "maw-dark-utility",
  "tokenKeys": [
    "bg", "surface-1", "surface-2", "surface-3", "border", "field",
    "text", "text-soft", "text-faint",
    "accent", "accent-2", "accent-soft", "on-accent",
    "good", "warn", "bad", "info"
  ],
  "tokenRoles": {
    "bg": "app canvas / part-body base",
    "surface-1": "raised chrome: top/bottom bars, part-header, nav",
    "surface-2": "panels, cards, zebra rows",
    "surface-3": "highest elevation: footers, popovers, menus",
    "border": "dividers, field borders, grid lines",
    "field": "input / editable field fill",
    "text": "primary text, field text, titles",
    "text-soft": "labels, secondary text",
    "text-faint": "tertiary, disabled, placeholder",
    "accent": "primary action / brand",
    "accent-2": "secondary accent, highlighted titles, focus ring",
    "accent-soft": "tinted accent surface (solid, not alpha)",
    "on-accent": "text/icon sitting on an accent fill",
    "good": "success / positive state",
    "warn": "warning state",
    "bad": "error / destructive state",
    "info": "informational state"
  },
  "fmpRoleMap": {
    "note": "How the retired FileMaker cv-* layout roles map onto the global contract, for native FMP theme building and render aliasing (resolve.js aliasMap).",
    "cv-bg": "bg",
    "cv-part-header": "surface-1",
    "cv-part-body": "bg",
    "cv-part-footer": "surface-3",
    "cv-field-fill": "field",
    "cv-field-border": "border",
    "cv-field-text": "text",
    "cv-label": "text-soft",
    "cv-accent": "accent",
    "cv-title": "text (use accent-2 for highlighted titles)"
  },
  "groups": [
    {
      "id": "utility",
      "label": "Utility",
