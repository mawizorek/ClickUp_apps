{
  "schemaVersion": 2,
  "note": "THE CANONICAL FILEMAKER OBJECT LIBRARY. The fundamental layout components a theme must be able to style, reskinned from the 4 vector grids (color x typography x forms x spacing). SINGLE SOURCE OF TRUTH: preview.html renders it dynamically and OBJECT-COVERAGE.md documents it. Keep the count in lockstep across all three. Two families: DISPLAY (shells/nav/type/buttons/fields/data/viewer) covers viewers; INPUT + FEEDBACK covers the tools you build inside (mappers/importers/inspectors). Expanded 2026-07-18 (T1 tokens, T2 tool objects, T3 viewer objects) from real-app audit of report-normalizer, prism, budget-code-mapper, dashboard, f1-racetracks.",
  "extensible": "NOT a hard cap. Any agent may add a new object when the design calls for one: append it to the right group here (id + name + states + props), add a row to OBJECT-COVERAGE.md, and it renders in the studio automatically (no preview.html code change). Tool/feedback/viewer object STYLES live in preview.objects.css (loaded after preview.css). The rule is only: add it AND document it. Never feel constrained by the current set.",
  "accentSystem": "accent = interactive/active (solid primary button, nav-on, focus, ghost text, active step/chip/segment, meter fill); accent-2 = structural energy + secondary-button highlight (edge rails, gradient stops). data-1..4 = categorical chart/series slots, shared across light/dark (typed-table types, legend swatches). font-mono carries all data/label/code text.",
  "tokenRoles": ["bg","surface-1","surface-2","surface-3","border","field","text","text-soft","text-faint","accent","accent-deep","accent-2","accent-soft","on-accent","good","warn","bad","info","data-1","data-2","data-3","data-4"],
  "typeRoles": ["font-display","font-body","font-mono"],
  "groups": {
    "shells": {
      "name": "Shells & containers",
      "desc": "Structural surfaces. Depth from surface fill + border + one outer shadow, with an accent-2 edge rail on elevated cards.",
      "objects": [
        { "id": "cnt_page_shell", "name": "Page shell", "rowLayout": false, "states": { "base": { "html": "<div class=\"tshell\">Page canvas &middot; app body surface</div>", "props": { "Fill": "bg", "Line": "border", "Corner": "radius-lg" } } } },
        { "id": "cnt_section_card", "name": "Section card", "rowLayout": false, "states": { "base": { "html": "<div class=\"tcard\"><h3>Section card</h3><p>A grouping card holds a related set of fields or content.</p></div>", "props": { "Fill": "surface-2", "Line": "border", "Top rail": "accent-2", "Corner": "radius-lg", "Shadow": "shadow-out" } } } },
        { "id": "cnt_toolbar", "name": "Toolbar", "rowLayout": false, "states": { "base": { "html": "<div class=\"ttoolbar\"><span class=\"tt\">On Track</span><span class=\"sp\"></span><span class=\"tnav on\">Live</span><span class=\"tnav off\">History</span></div>", "props": { "Fill": "surface-1", "Title": "text", "Nav on": "accent", "Nav off": "text-faint" } } } },
        { "id": "cnt_filter_bar", "name": "Filter bar", "rowLayout": false, "states": { "base": { "html": "<div class=\"ttoolbar\"><span class=\"tnav on\">All</span> <span class=\"tnav off\">Open</span> <span class=\"tnav off\">Closed</span></div>", "props": { "Fill": "surface-1", "Active chip": "accent", "Idle chip": "text-faint" } } } },
        { "id": "card_modal_standard", "name": "Modal", "rowLayout": false, "states": { "base": { "html": "<div class=\"tmodal\"><h3>Confirm action</h3><p>Highest elevation surface.</p><button class=\"tb primary\">Confirm</button></div>", "props": { "Fill": "surface-3", "Line": "border", "Top rail": "accent-2", "Corner": "radius-lg", "Shadow": "shadow-out" } } } }
      ]
    },
    "nav": {
      "name": "Navigation",
      "desc": "Active vs inactive must read at a glance.",
      "objects": [
        { "id": "nav_tab", "name": "Tabs", "rowLayout": true, "states": { "active": { "html": "<span class=\"tnav on\">Loans</span> <span class=\"tnav off\">Parties</span> <span class=\"tnav off\">Docs</span>", "props": { "Active": "accent", "On text": "on-accent", "Inactive": "text-faint" } }, "inactive": { "html": "<span class=\"tnav off\">Loans</span> <span class=\"tnav off\">Parties</span> <span class=\"tnav off\">Docs</span>", "props": { "Idle": "text-faint", "Line": "border" } } } },
        { "id": "nav_mode", "name": "Mode toggle", "rowLayout": true, "states": { "active": { "html": "<span class=\"tnav on\">List</span> <span class=\"tnav off\">Grid</span>", "props": { "Selected": "accent", "On text": "on-accent", "Unselected": "text-soft" } } } },
        { "id": "nav_back", "name": "Back affordance", "rowLayout": true, "states": { "base": { "html": "<button class=\"tb ghost\">&lsaquo; Back to hub</button>", "props": { "Text": "accent", "Fill": "transparent" } } } }
      ]
    },
    "type": {
      "name": "Typography",
      "desc": "Display + body + mono faces from Typography; ink colors from Color. Page titles carry an accent-grad leading tick.",
      "objects": [
        { "id": "tx_page_title", "name": "Page title", "rowLayout": false, "states": { "base": { "html": "<div class=\"ttype\"><div class=\"t1\">Loan application #4021</div></div>", "props": { "Face": "font-display", "Ink": "text", "Tick": "accent-grad", "Size": "fs-lead" } } } },
        { "id": "tx_section_header", "name": "Section + subsection header", "rowLayout": false, "states": { "base": { "html": "<div class=\"ttype\"><div class=\"t2\">Section header</div><div class=\"t2\" style=\"opacity:.7;font-size:0.82rem\">Subsection header</div></div>", "props": { "Face": "font-display", "Ink": "text" } } } },
        { "id": "tx_field_label", "name": "Field label", "rowLayout": false, "states": { "base": { "html": "<div class=\"tfield\"><label>Field label</label></div>", "props": { "Ink": "text-soft", "Size": "fs-xs" } } } },
        { "id": "tx_body", "name": "Body copy", "rowLayout": false, "states": { "base": { "html": "<div class=\"ttype\"><div class=\"t3\">Body copy is the standard reading size for record content and prose in the layout.</div></div>", "props": { "Ink": "text", "Size": "fs-body" } } } },
        { "id": "tx_mono_data", "name": "Mono data / code", "rowLayout": false, "states": { "base": { "html": "<div class=\"ttype\"><div class=\"t3\" style=\"font-family:var(--font-mono);font-variant-numeric:tabular-nums\">1:29.148 &nbsp; +0.204 &nbsp; LAP 47/58</div></div>", "props": { "Face": "font-mono", "Ink": "text", "Size": "fs-sm" } } } },
        { "id": "tx_helper_muted", "name": "Helper + muted", "rowLayout": false, "states": { "base": { "html": "<div class=\"ttype\"><div class=\"t4\">Helper text under a field.</div><div class=\"t5\">Muted metadata &middot; timestamps</div></div>", "props": { "Helper": "text-soft", "Muted": "text-faint" } } } },
        { "id": "tx_badge", "name": "Text badge", "rowLayout": true, "states": { "base": { "html": "<span class=\"tpill accent\">Featured</span>", "props": { "Fill": "accent-grad", "Text": "on-accent", "Corner": "radius-pill" } } } }
      ]
    },
    "buttons": {
      "name": "Buttons \u2014 full family",
      "desc": "Primary is a SOLID accent fill. Secondary is a highlight-pink outline (accent-2 text + border). Pressed swaps outer shadow for inner.",
      "objects": [
        { "id": "btn_family", "name": "Primary / secondary / quiet / destructive / icon", "rowLayout": true, "states": { "normal": { "html": "<button class=\"tb primary\">Primary</button> <button class=\"tb secondary\">Secondary</button> <button class=\"tb ghost\">Quiet</button> <button class=\"tb destructive\">Delete</button> <button class=\"tb icon\">&#9881;</button>", "props": { "Primary": "accent", "On text": "on-accent", "Secondary": "accent-2", "Destructive": "bad", "Shadow": "shadow-out", "Corner": "radius" } }, "pressed": { "html": "<button class=\"tb pressed\">Primary</button> <button class=\"tb secondary\" style=\"background:var(--surface-3);box-shadow:var(--shadow-in)\">Secondary</button> <button class=\"tb ghost\">Quiet</button>", "props": { "Fill": "accent", "Shadow": "shadow-in", "Transform": "translateY(1px)" } } } }
      ]
    },
    "fields": {
      "name": "Fields",
      "desc": "Focus = inner shadow + accent border. Readonly drops to a muted surface.",
      "objects": [
        { "id": "fd_text_standard", "name": "Text field", "rowLayout": false, "states": { "editable": { "html": "<div class=\"tfield\"><label>Driver name</label><input placeholder=\"Type a name...\"></div>", "props": { "Fill": "field", "Line": "border", "Corner": "radius" } }, "focus": { "html": "<div class=\"tfield\"><label>Driver name</label><input class=\"focus\" value=\"Lando Norris\"></div>", "props": { "Line": "accent", "Shadow": "shadow-in" } }, "readonly": { "html": "<div class=\"tfield\"><label>Team</label><input value=\"McLaren\" readonly style=\"background:var(--surface-2);color:var(--text-soft);pointer-events:none\"></div>", "props": { "Fill": "surface-2", "Text": "text-soft" } } } },
        { "id": "fd_dropdown_standard", "name": "Dropdown", "rowLayout": false, "states": { "base": { "html": "<div class=\"tfield\"><label>Team</label><div class=\"tselect\">McLaren <span>&#9662;</span></div></div>", "props": { "Fill": "field", "Line": "border", "Chevron": "text-faint" } } } },
        { "id": "fd_readonly_display", "name": "Readonly / calc display", "rowLayout": false, "states": { "base": { "html": "<div class=\"tfield\"><label>Computed total</label><div class=\"tro\">$48,210.00</div></div>", "props": { "Fill": "surface-2", "Text": "text-soft" } } } },
        { "id": "fd_search_filter", "name": "Search field", "rowLayout": false, "states": { "base": { "html": "<div class=\"tfield\"><label>Search</label><div class=\"tsearch\"><span>&#128269;</span><input placeholder=\"Search records...\"></div></div>", "props": { "Fill": "field", "Icon": "text-faint", "Line": "border" } } } }
      ]
    },
    "data": {
      "name": "Rows, tiles & badges",
      "desc": "The list-and-status family: portal rows (selected row carries an accent-2 left rail), metric tiles (accent-2 top rail), and status badges.",
      "objects": [
        { "id": "row_tile_badge", "name": "Portal rows / metric tiles / status badges", "rowLayout": false, "states": { "rows": { "html": "<table class=\"ttable\"><thead><tr><th>Pos</th><th>Driver</th><th class=\"n\">Pts</th></tr></thead><tbody><tr><td>1</td><td>Norris</td><td class=\"n\">287</td></tr><tr class=\"alt\"><td>2</td><td>Piastri</td><td class=\"n\">265</td></tr><tr class=\"sel\"><td>3</td><td>Verstappen</td><td class=\"n\">241</td></tr></tbody></table>", "props": { "Header": "text-soft", "Alternate": "surface-2", "Selected": "accent-soft", "Selected rail": "accent-2" } }, "tiles": { "html": "<div style=\"display:flex;gap:12px;flex-wrap:wrap;width:100%\"><div class=\"ttile\"><div class=\"big\">8,412</div><div class=\"lab\">Active this week</div></div><div class=\"ttile\"><div class=\"big\" style=\"color:var(--bad)\">3 overdue</div><div class=\"lab\">Needs attention</div></div></div>", "props": { "Fill": "surface-2", "Top rail": "accent-2", "Shadow": "shadow-out", "Alert": "bad" } }, "badges": { "html": "<div><span class=\"tpill neutral\">Draft</span> <span class=\"tpill good\">Active</span> <span class=\"tpill warn\">Pending</span> <span class=\"tpill bad\">Overdue</span></div>", "props": { "Neutral": "surface-3", "Good": "good", "Warn": "warn", "Alert": "bad" } } } }
      ]
    },
    "viewer": {
      "name": "Viewer & data-viz",
      "desc": "Display-side objects for dashboards + record viewers: score meter, prev/next pager, breadcrumb trail, and a data-viz legend keyed to data-1..4. From f1-racetracks.",
      "objects": [
        { "id": "viz_meter", "name": "Meter / progress bar", "rowLayout": false, "states": { "inline": { "html": "<div class=\"ometer\"><span class=\"om-score\">7.4<small>/10</small></span><span class=\"om-track\"><i class=\"om-fill\" style=\"width:74%\"></i></span><span class=\"om-word\">Strong</span></div>", "props": { "Fill": "accent-grad", "Track": "surface-3", "Score": "font-mono", "Word": "accent" } }, "stacked": { "html": "<div class=\"ometer stack\"><div class=\"om-top\"><span>Import progress</span><b>68%</b></div><span class=\"om-track\"><i class=\"om-fill\" style=\"width:68%\"></i></span></div>", "props": { "Fill": "accent-grad", "Track": "surface-3", "Value": "font-mono" } } } },
        { "id": "viz_pager", "name": "Prev / next pager", "rowLayout": false, "states": { "base": { "html": "<div class=\"opager\"><button class=\"opn\"><div class=\"opn-l\">Prev</div><div class=\"opn-n\">Silverstone</div></button><button class=\"opn next\"><div class=\"opn-l\">Next</div><div class=\"opn-n\">Hungaroring</div></button></div>", "props": { "Fill": "surface-2", "Line": "border", "Hover line": "accent", "Label": "font-mono" } } } },
        { "id": "viz_breadcrumb", "name": "Breadcrumb", "rowLayout": true, "states": { "base": { "html": "<nav class=\"ocrumb\"><a>Home</a><span class=\"ocb-sep\">/</span><a>Circuits</a><span class=\"ocb-sep\">/</span><span class=\"ocb-cur\">Hungaroring</span></nav>", "props": { "Face": "font-mono", "Link": "text-soft", "Hover": "accent", "Current": "text" } } } },
        { "id": "viz_legend", "name": "Data-viz legend", "rowLayout": false, "states": { "base": { "html": "<div class=\"olegend\"><span class=\"oleg\"><span class=\"osw s1\"></span>Sector 1</span><span class=\"oleg\"><span class=\"osw s2\"></span>Sector 2</span><span class=\"oleg\"><span class=\"osw s3\"></span>Sector 3</span><span class=\"oleg\"><span class=\"oln\"></span>Ideal lap</span></div>", "props": { "Series 1": "data-1", "Series 2": "data-2", "Series 3": "data-3", "Line": "accent" } } } }
      ]
    },
    "input": {
      "name": "Input & workflow",
      "desc": "The tool vocabulary: how you get data IN and move through a build step-by-step. From report-normalizer / budget-code-mapper / prism.",
      "objects": [
        { "id": "fd_dropzone", "name": "Dropzone", "rowLayout": false, "states": { "base": { "html": "<div class=\"odrop\"><div class=\"oico\">\u2913</div><h4>Drop a file to begin</h4><p>or click to browse. CSV, JSON, and Markdown supported.</p><div class=\"oexts\"><span class=\"oext\">.csv</span><span class=\"oext\">.json</span><span class=\"oext\">.md</span></div></div>", "props": { "Fill": "surface-1", "Dashed line": "border", "Hover line": "accent", "Ext tag": "font-mono" } } } },
        { "id": "wf_stepper", "name": "Stepper / progress rail", "rowLayout": true, "states": { "base": { "html": "<div class=\"ostep-rail\"><span class=\"ostep done\"><span class=\"on\">\u2713</span>Upload</span><span class=\"ostep active\"><span class=\"on\">2</span>Map</span><span class=\"ostep\"><span class=\"on\">3</span>Preview</span><span class=\"ostep\"><span class=\"on\">4</span>Export</span></div>", "props": { "Done": "good", "Active": "accent", "Active fill": "accent-soft", "Idle": "text-faint" } } } },
        { "id": "map_row", "name": "Mapping row", "rowLayout": false, "states": { "base": { "html": "<div class=\"omap\"><span class=\"osrc\">source_column_a</span><span class=\"oarrow\">\u2192</span><span class=\"oops\"><span class=\"ochip on\">trim</span><span class=\"ochip\">upper</span><span class=\"ochip\">date</span></span><span class=\"otgt\">Target field <span>\u25be</span></span></div>", "props": { "Source": "font-mono", "Op on": "accent", "Target fill": "field", "Line": "border" } } } },
        { "id": "ctl_toggle", "name": "Toggle switch", "rowLayout": true, "states": { "off": { "html": "<span class=\"oswitch-row\"><span class=\"oswitch\"></span> Skip empty rows</span>", "props": { "Track": "surface-3", "Knob": "text-faint" } }, "on": { "html": "<span class=\"oswitch-row\"><span class=\"oswitch on\"></span> Skip empty rows</span>", "props": { "Track on": "accent-soft", "Knob on": "accent" } } } },
        { "id": "ctl_chip", "name": "Chip toggle", "rowLayout": true, "states": { "base": { "html": "<span class=\"ochip on\">Podiums</span> <span class=\"ochip\">Points</span> <span class=\"ochip\">DNF</span>", "props": { "On text": "text", "On line": "accent", "On fill": "accent-soft", "Idle": "text-faint" } } } },
        { "id": "ctl_segmented", "name": "Segmented control", "rowLayout": true, "states": { "base": { "html": "<div class=\"oseg\"><button class=\"on\">Table</button><button>Tree</button><button>Raw</button></div>", "props": { "Selected": "accent", "On text": "on-accent", "Idle": "text-soft", "Line": "border" } } } },
        { "id": "btn_icon", "name": "Icon button", "rowLayout": true, "states": { "base": { "html": "<button class=\"oiconbtn\">\u2699</button> <button class=\"oiconbtn\">\u21bb</button> <button class=\"oiconbtn\">\u2197</button>", "props": { "Fill": "surface-2", "Icon": "text-soft", "Hover line": "accent" } } } },
        { "id": "panel_drawer", "name": "Side drawer", "rowLayout": false, "states": { "base": { "html": "<div class=\"odrawer\"><div class=\"od-h\"><h4>Settings</h4><button class=\"oiconbtn\">\u2715</button></div><div class=\"od-b\"><div class=\"od-row\"><span>Theme</span><span class=\"oswitch on\"></span></div><div class=\"od-row\"><span>Auto-refresh</span><span class=\"oswitch\"></span></div><div class=\"od-row\"><span>Compact rows</span><span class=\"oswitch on\"></span></div></div></div>", "props": { "Fill": "surface-1", "Line": "border", "Elevation": "elev-3", "Corner": "radius-lg" } } } }
      ]
    },
    "feedback": {
      "name": "Feedback & data readout",
      "desc": "How a tool talks back: validation, status, typed data, and the record-detail readout. From prism / report-normalizer.",
      "objects": [
        { "id": "fb_banner", "name": "Inline banner / alert", "rowLayout": false, "states": { "match": { "html": "<div class=\"obanner match\"><span class=\"ob-ic\">\u2713</span> All 12 columns matched a target field.</div>", "props": { "Line": "good", "Tint": "good" } }, "warn": { "html": "<div class=\"obanner warn\"><span class=\"ob-ic\">\u26a0</span> 2 columns are unmapped and will be dropped.</div>", "props": { "Line": "warn", "Tint": "warn" } }, "bad": { "html": "<div class=\"obanner bad\"><span class=\"ob-ic\">\u2715</span> Parse failed on row 47: unexpected token.</div>", "props": { "Line": "bad", "Tint": "bad" } } } },
        { "id": "fb_flag", "name": "Flag / callout item", "rowLayout": false, "states": { "base": { "html": "<div class=\"oflag warn\"><span class=\"of-ic\">\u26a0</span><span><b>Mixed types</b> <span class=\"of-x\">column price has 4 strings among 200 numbers.</span></span></div><div class=\"oflag ok\"><span class=\"of-ic\">\u2713</span><span><b>Clean key</b> <span class=\"of-x\">id is unique across all rows.</span></span></div>", "props": { "Warn": "warn", "OK": "good", "Title": "text", "Body": "text-soft" } } } },
        { "id": "data_kv_panel", "name": "KV stat panel", "rowLayout": false, "states": { "base": { "html": "<div class=\"okv\"><div class=\"okv-h\">File stats</div><div class=\"okv-row\"><span class=\"okv-k\">Rows</span><span class=\"okv-v\">8,412</span></div><div class=\"okv-row\"><span class=\"okv-k\">Columns</span><span class=\"okv-v\">12</span></div><div class=\"okv-row\"><span class=\"okv-k\">Size</span><span class=\"okv-v\">1.9 MB</span></div></div>", "props": { "Fill": "surface-1", "Key": "text-soft", "Value": "font-mono", "Elevation": "elev-1" } } } },
        { "id": "data_typed_table", "name": "Typed data table", "rowLayout": false, "states": { "base": { "html": "<div class=\"otblwrap\"><table class=\"otbl\"><thead><tr><th class=\"orownum\">#</th><th>id<span class=\"oty\">int</span></th><th>name<span class=\"oty\">string</span></th><th>active<span class=\"oty\">bool</span></th></tr></thead><tbody><tr><td class=\"orownum\">1</td><td><span class=\"onum\">1001</span></td><td>Norris</td><td><span class=\"obool\">true</span></td></tr><tr><td class=\"orownum\">2</td><td><span class=\"onum\">1002</span></td><td>Piastri</td><td><span class=\"obool\">true</span></td></tr><tr><td class=\"orownum\">3</td><td><span class=\"onum\">1003</span></td><td><span class=\"onull\">null</span></td><td><span class=\"obool\">false</span></td></tr></tbody></table></div>", "props": { "Header": "surface-2", "Type label": "font-mono", "Number": "data-1", "Bool": "data-2", "Null": "text-faint" } } } },
        { "id": "fb_toast", "name": "Toast", "rowLayout": true, "states": { "base": { "html": "<span class=\"otoast\"><span class=\"ot-ic\">\u2713</span> Copied to clipboard</span>", "props": { "Fill": "surface-3", "Icon": "good", "Elevation": "elev-2" } } } },
        { "id": "fb_empty", "name": "Empty / error state", "rowLayout": false, "states": { "empty": { "html": "<div class=\"oempty\"><div class=\"oe-ic\">\u25a1</div><h4>No records yet</h4><p>Import a file or add a row to get started.</p></div>", "props": { "Icon fill": "surface-2", "Title": "text", "Body": "text-soft" } }, "error": { "html": "<div class=\"oempty err\"><div class=\"oe-ic\">\u2715</div><h4>Couldn't load data</h4><p>The source returned a 404. Check the path and retry.</p></div>", "props": { "Icon": "bad", "Title": "text", "Body": "text-soft" } } } }
      ]
    }
  }
}
