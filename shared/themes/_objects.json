{
  "schemaVersion": 1,
  "note": "THE CANONICAL FILEMAKER OBJECT LIBRARY. These are the 20 fundamental layout components. Themes style these objects; they do not invent new ones.",
  "groups": {
    "type": {
      "name": "Typography Ramp",
      "desc": "Display + body faces from Typography; ink colors from Color.",
      "objects": [
        {
          "id": "tx_ramp",
          "name": "Type ramp",
          "rowLayout": false,
          "states": {
            "normal": {
              "html": "<div class=\"ttype\"><div class=\"t1\">Race weekend</div><div class=\"t2\">Section header</div><div class=\"t3\">Body copy is the standard reading size for record content and prose in the layout.</div><div class=\"t4\">Helper text under a field.</div><div class=\"t5\">Muted metadata · timestamps</div></div>",
              "props": { "Display": "font-display", "Body": "font-body", "Lead": "fs-lead", "Standard": "fs-body" }
            }
          }
        }
      ]
    },
    "buttons": {
      "name": "Buttons — full state set",
      "desc": "Primary uses the two-stop hex gradient. Pressed swaps outer shadow for inner.",
      "objects": [
        {
          "id": "btn_primary",
          "name": "Primary",
          "rowLayout": true,
          "states": {
            "normal": { "html": "<button class=\"tb primary\">Save changes</button>", "props": { "Fill": "accent-grad", "Corner": "radius", "Shadow": "shadow-out", "Text": "on-accent" } },
            "hover": { "html": "<button class=\"tb primary\" style=\"filter:brightness(1.15)\">Save changes</button>", "props": { "Note": "brightness(1.15) or opacity" } },
            "pressed": { "html": "<button class=\"tb pressed\">Save changes</button>", "props": { "Fill": "accent-grad", "Shadow": "shadow-in", "Transform": "translateY(1px)" } }
          }
        },
        {
          "id": "btn_secondary",
          "name": "Secondary",
          "rowLayout": true,
          "states": {
            "normal": { "html": "<button class=\"tb secondary\">Cancel</button>", "props": { "Fill": "surface-2", "Line": "border", "Text": "text" } },
            "pressed": { "html": "<button class=\"tb secondary\" style=\"background:var(--surface-3);box-shadow:var(--shadow-in)\">Cancel</button>", "props": { "Fill": "surface-3", "Shadow": "shadow-in" } }
          }
        },
        {
          "id": "btn_destructive",
          "name": "Destructive",
          "rowLayout": true,
          "states": {
            "normal": { "html": "<button class=\"tb destructive\">Delete</button>", "props": { "Fill": "bad", "Text": "#ffffff", "Shadow": "shadow-out" } },
            "pressed": { "html": "<button class=\"tb destructive\" style=\"box-shadow:var(--shadow-in);transform:translateY(1px)\">Delete</button>", "props": { "Shadow": "shadow-in" } }
          }
        },
        {
          "id": "btn_ghost",
          "name": "Ghost + icon",
          "rowLayout": true,
          "states": {
            "normal": { "html": "<button class=\"tb ghost\">Details</button><button class=\"tb icon\">★</button>", "props": { "Ghost": "transparent", "Text": "accent", "Size": "touch" } }
          }
        }
      ]
    },
    "shells": {
      "name": "Shells, toolbar, nav & modal",
      "desc": "Depth from surface fill + border + one outer shadow.",
      "objects": [
        {
          "id": "cnt_toolbar",
          "name": "Toolbar + nav",
          "rowLayout": false,
          "states": {
            "normal": { "html": "<div class=\"ttoolbar\"><span class=\"tt\">On Track</span><span class=\"sp\"></span><span class=\"tnav on\">Live</span><span class=\"tnav off\">History</span></div>", "props": { "Fill": "surface-1", "Nav on": "accent", "Nav off": "text-faint" } }
          }
        },
        {
          "id": "cnt_card",
          "name": "Section card",
          "rowLayout": false,
          "states": {
            "normal": { "html": "<div class=\"tcard\"><h3>Constructor standings</h3><p>Surface fill + border + one outer shadow for depth.</p></div>", "props": { "Fill": "surface-2", "Corner": "radius-lg", "Shadow": "shadow-out" } }
          }
        },
        {
          "id": "cnt_modal",
          "name": "Modal",
          "rowLayout": false,
          "states": {
            "normal": { "html": "<div class=\"tmodal\"><h3>Confirm action</h3><p>Highest elevation surface.</p><button class=\"tb primary\">Confirm</button></div>", "props": { "Fill": "surface-3", "Corner": "radius-lg", "Shadow": "shadow-out" } }
          }
        },
        {
          "id": "cnt_callout",
          "name": "Callout",
          "rowLayout": false,
          "states": {
            "normal": { "html": "<div class=\"tcallout\">Accent-soft fill, accent border. Retints with the color.</div>", "props": { "Fill": "accent-soft", "Line": "accent", "Corner": "radius" } }
          }
        }
      ]
    },
    "fields": {
      "name": "Fields — editable, focus, readonly",
      "desc": "Focus = inner shadow + accent border.",
      "objects": [
        {
          "id": "fd_text",
          "name": "Text field",
          "rowLayout": false,
          "states": {
            "editable": { "html": "<div class=\"tfield\"><label>Driver name</label><input placeholder=\"Type a name...\"></div>", "props": { "Fill": "field", "Line": "border", "Corner": "radius" } },
            "focus": { "html": "<div class=\"tfield\"><label>Driver name</label><input class=\"focus\" value=\"Lando Norris\"></div>", "props": { "Line": "accent", "Shadow": "shadow-in" } },
            "readonly": { "html": "<div class=\"tfield\"><label>Team</label><input value=\"McLaren\" readonly style=\"background:var(--surface-2);color:var(--text-soft);pointer-events:none\"></div>", "props": { "Fill": "surface-2", "Text": "text-soft" } }
          }
        }
      ]
    },
    "pills": {
      "name": "Pills, tiles & callout",
      "desc": "Pill radius follows the feeling; semantic fills from good/warn/bad/info.",
      "objects": [
        {
          "id": "tx_badge",
          "name": "Pills & badges",
          "rowLayout": true,
          "states": {
            "normal": { "html": "<div><span class=\"tpill accent\">Featured</span> <span class=\"tpill good\">Confirmed</span> <span class=\"tpill warn\">Pending</span> <span class=\"tpill bad\">Blocked</span> <span class=\"tpill info\">Note</span></div>", "props": { "Accent": "accent-grad", "Corner": "radius-pill", "Padding": "pad-cell" } }
          }
        },
        {
          "id": "sum_tile",
          "name": "Metric tile",
          "rowLayout": false,
          "states": {
            "normal": { "html": "<div class=\"ttile\"><div class=\"big\">8,412</div><div class=\"lab\">Active this week</div></div>", "props": { "Fill": "surface-2", "Shadow": "shadow-out", "Pad": "pad-card" } }
          }
        }
      ]
    },
    "tables": {
      "name": "Table & portal rows",
      "desc": "Header, standard, alternating, selected.",
      "objects": [
        {
          "id": "row_portal",
          "name": "Table rows",
          "rowLayout": false,
          "states": {
            "header": { "html": "<table class=\"ttable\"><thead><tr><th>Pos</th><th>Driver</th><th class=\"n\">Pts</th></tr></thead><tbody><tr><td>1</td><td>Norris</td><td class=\"n\">287</td></tr></tbody></table>", "props": { "Fill": "transparent", "Text": "text-soft" } },
            "standard": { "html": "<table class=\"ttable\"><thead><tr><th>Pos</th><th>Driver</th><th class=\"n\">Pts</th></tr></thead><tbody><tr><td>1</td><td>Norris</td><td class=\"n\">287</td></tr></tbody></table>", "props": { "Fill": "transparent", "Line": "border" } },
            "alternate": { "html": "<table class=\"ttable\"><thead><tr><th>Pos</th><th>Driver</th><th class=\"n\">Pts</th></tr></thead><tbody><tr class=\"alt\"><td>2</td><td>Piastri</td><td class=\"n\">265</td></tr></tbody></table>", "props": { "Fill": "surface-2" } },
            "selected": { "html": "<table class=\"ttable\"><thead><tr><th>Pos</th><th>Driver</th><th class=\"n\">Pts</th></tr></thead><tbody><tr class=\"sel\"><td>3</td><td>Verstappen</td><td class=\"n\">241</td></tr></tbody></table>", "props": { "Fill": "accent-soft" } }
          }
        }
      ]
    }
  }
}